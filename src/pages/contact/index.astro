---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site';
---

<BaseLayout title="Contact | Franco Lopez" description="Contact Franco Lopez for Platform Engineer, DevOps Engineer, SRE, and Cloud Infrastructure opportunities.">
  <header class="page-header">
    <span class="eyebrow">contact</span>
    <h1>Let’s connect.</h1>
  </header>

  <section class="grid">
    <a class="card" href={`mailto:${site.email}`}>
      <h3>Email</h3>
      <p>{site.email}</p>
    </a>
    <a class="card" href="https://www.linkedin.com/in/jfranco-lopez/">
      <h3>LinkedIn</h3>
      <p>Connect for recruiting, engineering, and role conversations.</p>
    </a>
    <a class="card" href="https://github.com/jfrancolopez">
      <h3>GitHub</h3>
      <p>Code, notes, experiments, homelab, and automation work.</p>
    </a>
    <a class="card" href="/FrancoLopez-Resume.pdf">
      <h3>Resume</h3>
      <p>Download the current PDF resume.</p>
    </a>
  </section>
</BaseLayout>
