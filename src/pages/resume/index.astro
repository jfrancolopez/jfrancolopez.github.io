---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfilePhoto from '../../components/ProfilePhoto.astro';
import { resume } from '../../data/resume.js';

// Normalize bullets to support both string and {text} object shapes
const bulletText = (b) => (typeof b === 'string' ? b : b.text);
---
<BaseLayout
  title={`Resume | ${resume.name}`}
  description={`Resume for ${resume.name}, platform and DevOps engineer based in Raleigh-Durham, NC.`}
>
  <header class="page-header resume-header">
    <span class="eyebrow">resume</span>
    <h1>{resume.headline}</h1>
    <p class="resume-meta">{resume.location} · {resume.availability}</p>
  </header>

  <section class="resume-intro" aria-label="Resume introduction">
    <div class="resume-intro-copy">
      <p class="lead">{resume.summary}</p>
      <div class="actions">
        <a class="button primary" href="/FrancoLopez-Resume.pdf">Download PDF</a>
        <a class="button" href={`mailto:${resume.contact.email}`}>Email me</a>
        <a class="button" href={`https://${resume.contact.linkedin}`} target="_blank" rel="noopener">LinkedIn</a>
        <a class="button" href={`https://${resume.contact.github}`} target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
    <ProfilePhoto />
  </section>

  <article class="content">
    <h2>Technical Focus</h2>
    <ul class="skills-list">
      {resume.skills.map((skill) => (
        <li><strong>{skill.label}:</strong> {skill.items.join(', ')}</li>
      ))}
    </ul>

    <h2>Experience</h2>
    {resume.experience.map((job) => (
      <section class="experience-entry">
        <h3>{job.company} · {job.role}</h3>
        {job.companyContext && <p class="company-context"><em>{job.companyContext}</em></p>}
        <p class="job-meta">{job.location} · {job.dates}</p>
        <ul>
          {job.bullets.map((bullet) => <li>{bulletText(bullet)}</li>)}
        </ul>
        {job.stack && (
          <p class="stack-line"><strong>Stack:</strong> {job.stack.join(' · ')}</p>
        )}
      </section>
    ))}

    <h2>Projects</h2>
    {resume.projects.map((project) => (
      <section class="project-entry">
        <h3>
          {project.url ? (
            <a href={`https://${project.url}`} target="_blank" rel="noopener">{project.name}</a>
          ) : (
            project.name
          )}
        </h3>
        <p>{project.description}</p>
        {project.stack && (
          <p class="stack-line"><strong>Stack:</strong> {project.stack.join(' · ')}</p>
        )}
      </section>
    ))}

    <h2>Education and Certifications</h2>
    <ul class="cert-list">
      {resume.educationAndCertifications.map((item) => (
        <li>
          <strong>{item.title}</strong> — {item.issuer} <span class="cert-status">({item.status})</span>
        </li>
      ))}
    </ul>

    <h2>Currently Learning</h2>
    <ul>
      {resume.currentlyLearning.map((item) => <li>{item}</li>)}
    </ul>

    <h2>Languages</h2>
    <p>{resume.languages.join(' and ')}.</p>
  </article>
</BaseLayout>
