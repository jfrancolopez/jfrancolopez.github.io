---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
---

<BaseLayout title="Franco Lopez | Personal Technology Notebook" description="A quiet personal notebook on software, systems, infrastructure, tools, and working through technology.">
  <section class="cover-page" aria-labelledby="cover-title">
    <div class="cover-card">
      <ProfilePhoto />

      <div class="cover-kicker" aria-hidden="true">
        <span>~/notes</span>
        <span class="cursor"></span>
      </div>

      <h1 id="cover-title">Franco Lopez</h1>

      <p class="cover-intro">
        A quiet place where I write through software, systems, infrastructure,
        and the tools I use to understand them.
      </p>

      <p class="cover-subtitle">
        Part notebook, part blog, part archive.
      </p>

      <nav class="cover-links" aria-label="Homepage links">
        <a href="/blog/">Notes</a>
        <a href="/resume/">About / Resume</a>
        <a href="/contact/">Contact</a>
      </nav>
    </div>
  </section>
</BaseLayout>
